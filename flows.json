    {
        "id": "42e3f51f823a76fb",
        "type": "function",
        "z": "3ad35fb3ec9b6551",
        "name": "Math Core Engine",
        "func": "let windowSize = 25;\nlet attackCount = global.get(\"attack_count\") || 0;\nif (global.get(\"math_core_reset\") === true) {\n    context.set(\"values\", []);\n    context.set(\"ipHitMap\", {});\n    context.set(\"lastState\", 0);\n    global.set(\"math_core_reset\", false);\n}\nlet values = context.get(\"values\") || [];\nlet d = msg.payload;\nif (!d || typeof d.pps === \"undefined\" || d.top_ip === \"0.0.0.0\") return null;\n\nlet currentPPS = Number(d.pps);\nlet topIP = d.top_ip || \"Unknown\";\nlet zone = d.zone || \"UNKNOWN\";\n\nvalues.push(currentPPS);\nif (values.length > windowSize) values.shift();\ncontext.set(\"values\", values);\nlet sum = values.reduce((a, b) => a + b, 0);\nlet mean = sum / (values.length || 1);\nlet variance = values.reduce((a, b) => a + Math.pow(b - mean, 2), 0) / (values.length || 1);\nlet stdDev = Math.sqrt(variance);\nlet zScore = stdDev === 0 ? 0 : (currentPPS - mean) / stdDev;\n\nlet state = 0;\nlet isWarning = (currentPPS > 80 || zScore > 3.0);\nlet ipHitMap = context.get(\"ipHitMap\") || {};\nlet nowSec = Math.floor(Date.now() / 1000);\n\nif (isWarning) {\n    let hitHistory = ipHitMap[topIP] || [];\n    hitHistory.push(nowSec);\n    hitHistory = hitHistory.filter(t => (nowSec - t) <= 5);\n    ipHitMap[topIP] = hitHistory;\n    if (hitHistory.length >= 2) {\n        state = 2; // RED (Block Table)\n    } else {\n        state = 1; // ORANGE (Threat Table)\n    }\n} else {\n    if (ipHitMap[topIP]) {\n        ipHitMap[topIP] = ipHitMap[topIP].filter(t => (nowSec - t) <= 5);\n    }\n    state = 0; // GREEN\n}\ncontext.set(\"ipHitMap\", ipHitMap);\n\nlet lastState = context.get(\"lastState\") || 0;\nlet isNewAttack = (state === 2 && lastState !== 2);\ncontext.set(\"lastState\", state);\nif (isNewAttack) attackCount += 1;\n\nglobal.set(\"global_ip\", topIP);\nglobal.set(\"global_zscore\", Number(zScore.toFixed(2)));\nglobal.set(\"global_pps\", currentPPS);\nglobal.set(\"attack_count\", attackCount);\n\nmsg.payload = {\n    pps: currentPPS,\n    ip: topIP,\n    zscore: Number(zScore.toFixed(2)),\n    state: state,\n    zone: zone,\n    is_new_attack: isNewAttack,\n    total_attacks: attackCount,\n    avg_len: d.avg_len || 0\n};\nreturn msg;",
