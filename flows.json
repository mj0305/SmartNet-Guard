        "z": "3ad35fb3ec9b6551",
        "name": "Threat Log (Heuristic Accumulator)",
        "func": "let history = context.get(\"history\") || [];\nlet d = msg.payload;\nif (global.get(\"math_core_reset\") === true || (Array.isArray(d) && d.length === 0)) {\n    context.set(\"history\", []);\n    global.set(\"attack_history\", []);\n    msg.payload = [];\n    return msg;\n}\nconst NORMAL_ZONES = [\"INTERNAL\", \"LOCALHOST\"];\nif (d && typeof d.pps !== \"undefined\") {\n    let isThreat = (d.state === 1 || d.state === 2);\n    let isNormal = NORMAL_ZONES.includes(d.zone);\n    if (isThreat && !isNormal) {\n        let timeStr = new Date().toLocaleTimeString();\n        let lastRecord = history.length > 0 ? history[0] : null;\n        if (!lastRecord || lastRecord.ip !== d.ip || lastRecord.time !== timeStr) {\n            history.unshift({\n                time: timeStr, IP: d.ip, PPS: d.pps,\n                Z_Score: d.zscore, Zone: d.zone || \"UNKNOWN\"\n            });\n            if (history.length > 15) history.pop();\n            context.set(\"history\", history);\n            global.set(\"attack_history\", history);\n        }\n    }\n}\nmsg.payload = history;\nreturn msg;",
