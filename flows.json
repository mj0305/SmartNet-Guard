        "id": "9f2154c3f61002e8",
        "type": "function",
        "z": "3ad35fb3ec9b6551",
        "name": "Auth Result Parser",
        "func": "let out = (msg.payload || \"\").toString().trim();\nlet success = false;\nlet message = \"\";\nlet name = \"Admin\";\nlet kb = { reply_markup: { keyboard: [[{text:\"/status\"},{text:\"/on\"}],[{text:\"/off\"},{text:\"/reset\"}]], resize_keyboard: true } };\n\nif (out.includes(\"AUTHORIZED\")) {\n    if (out.includes(\":\")) name = out.split(\":\")[1].trim();\n    success = true;\n    message = \"✅ Auth Success: \" + name;\n    global.set(\"auth_status\", true);\n} else {\n    let reason = \"UNKNOWN\";\n    if (out.includes(\"DENIED:\")) reason = out.split(\"DENIED:\")[1].trim();\n    success = false;\n    message = \"🚫 Auth Failed: \" + reason;\n    global.set(\"auth_status\", false);\n}\n\nmsg.authResult = { success: success, message: message };\nmsg.filename = \"/tmp/auth_frame.jpg\";\n\nlet startMsg = success ? { payload: \"start\" } : null;\nlet tgMsg = { \n    payload: { \n        chatId: \"8105394541\", \n        type: \"message\", \n        content: success ? \"✅ Face ID verified. System unlocked & probe active.\" : \"🚫 Face ID failed. Access denied.\",\n        options: kb\n    } \n};\nlet lcdMsg = success ? null : { payload: \"\\\"ACCESS DENIED \\\\nADMIN ONLY \\\"\" };\n\nreturn [msg, startMsg, tgMsg, lcdMsg];",
