        "name": "Format Telegram Message",
        "func": "if (!msg.payload || !msg.payload.is_new_attack) return null;\n\nlet d = msg.payload;\nlet kb = { reply_markup: { keyboard: [[{text:\"/status\"},{text:\"/on\"}],[{text:\"/off\"},{text:\"/reset\"}]], resize_keyboard: true } };\nlet alertMsg = \"🚨 ALERT: Volumetric DDoS Flood Detected! 🚨\\n\\n🎯 Malicious Source IP: \" + d.ip + \"\\n📊 Telemetry Traffic: \" + d.pps + \" PPS\\n📈 Deviation Index (Z): \" + d.zscore + \"\\n⚠️ Cumulative Interceptions: \" + d.total_attacks + \"\\n\\n[Linux Kernel Netfilter automated mitigation initiated]\";\nmsg.payload = { chatId: \"8105394541\", type: \"message\", content: alertMsg, options: kb };\nreturn msg;",
